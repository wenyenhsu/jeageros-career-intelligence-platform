SECRET_KEY=change-me
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1
DB_NAME=jaegeros
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Celery / crawl (optional)
# CRAWL_SCHEDULE_SECONDS=900
# CRAWL_SKILL_PIPELINE_ENABLED=true

# SkillSet pgvector embedding sync (resume RAG + market fit)
# SKILL_EMBEDDING_SCHEDULE_SECONDS=3600
# SKILL_EMBEDDING_BATCH_LIMIT=100
# SKILL_EMBEDDING_SYNC_ENABLED=true
# SKILL_EMBEDDING_SYNC_AFTER_CRAWL=true

# Ollama (optional; defaults work in Docker with host Ollama)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_SKILL_MODEL=qwen2.5-coder:7b
# OLLAMA_EMBEDDING_MODEL=mxbai-embed-large
